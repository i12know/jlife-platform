includes:
	- vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
	level: 5
	paths:
		- plugins
	scanFiles:
		- vendor/php-stubs/wp-cli-stubs/wp-cli-stubs.php
	excludePaths:
		# Test files bootstrap against the WP test suite (WP_TESTS_DIR),
		# which is not present at analysis time.
		- plugins/*/tests/*
		- plugins/*/vendor/*
